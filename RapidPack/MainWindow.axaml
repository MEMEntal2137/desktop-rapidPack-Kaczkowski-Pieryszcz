<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1000"
        d:DesignHeight="800"
        x:Class="RapidPack.MainWindow"
        Title="RapidPack"
        Icon="assets/favicon.ico">

    <Grid>
        <Image Source="assets/background.jpg" Stretch="UniformToFill"/>

        <StackPanel Width="800"
                    Height="600"
                    Background="LightYellow"
                    HorizontalAlignment="Left"
                    Margin="20">

            <TextBlock Foreground="Black"
                       HorizontalAlignment="Center"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="5,5,5,20">
                Szczegóły Zamówienia
            </TextBlock>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock Foreground="Black" Padding="20">
                    Wysokość paczki (w cm):
                </TextBlock>
                <TextBox x:Name="Height" Width="100" Height="40"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock Foreground="Black" Padding="20">
                    Szerokość paczki (w cm):
                </TextBlock>
                <TextBox x:Name="Width" Width="100" Height="40"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock Foreground="Black" Padding="20">
                    Głębokość paczki (w cm):
                </TextBlock>
                <TextBox x:Name="Deep" Width="100" Height="40"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock Foreground="Black" Padding="20" x:Name="WagaCheck">
                    Waga paczki (w kg):
                </TextBlock>
                <TextBox x:Name="Weight"
                         TextChanged="Weight_OnTextChanged"
                         Width="100"
                         Height="40"
                         Margin="30,0,0,0"/>
            </StackPanel>

            <CheckBox Foreground="Black"
                      x:Name="Express"
                      HorizontalAlignment="Center"
                      Content="Ekspres (+15zł)"
                      Padding="20,10"
                      Margin="0,30,0,10"/>

            <ComboBox HorizontalAlignment="Center"
                      x:Name="TypeOfPackage"
                      SelectedIndex="0"
                      Width="220"
                      Margin="0,10">
                <ComboBoxItem x:Name="Standard" Content="Standardowa (10zł)"/>
                <ComboBoxItem x:Name="Paleta" Content="Paleta (100zł)"/>
                <ComboBoxItem x:Name="Glass" Content="Ostrożnie szkło (20zł)"/>
            </ComboBox>

            <Button Click="Submit_OnClick"
                    Content="Wyceń"
                    HorizontalAlignment="Center"
                    x:Name="Submit"
                    Foreground="Black"
                    Padding="30,12"
                    Margin="0,30,0,0"
                    Background="RoyalBlue"/>
        </StackPanel>

        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="25">

            <Border BorderBrush="FloralWhite"
                    BorderThickness="5">
                <TextBlock Background="BlanchedAlmond"
                           x:Name="ShowText"
                           Width="400"
                           Height="600"
                           TextDecorations="Underline"
                           Padding="5"
                           TextAlignment="Center"/>
            </Border>

        </StackPanel>

    </Grid>
</Window>